-- we want to know how many people only clicked once and left, and how many people clicked more than once and stayed 
--start by grouping each event level to user level 
with user_events as (
select user_pseudo_id, count (*) as Total_events --( Number of events) -- so now we are creating a table that shows each user's events. It groups every event from a particular user. 
from `bigquery-public-data.ga4_obfuscated_sample_ecommerce.events_*`
group by user_pseudo_id 
)
select  -- this side assigns the classification logic
case 
when Total_events  = 1 then 'One-Time user' else 'Repeat'
end as Type_of_user,
count (*) as users 
from user_events
group by Type_of_user;

