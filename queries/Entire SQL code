CREATE OR REPLACE TABLE `sql-churn-analysis.analytics.USER_CHURN` AS

--SELECT ---- just put this part here because I want to see how this forms 
 -- churn_group,
  --COUNT(*) AS users
--FROM ( ---- same -- want ot see how it forms 
WITH 
        USER_LAST_ACTIVITY 
        AS(   -- this is a CTE structure that creates a temporary table in to call from 
SELECT  user_pseudo_id, max(SAFE.PARSE_DATE('%Y%m%d', event_date)) AS last_activity_date ,min(SAFE.PARSE_DATE('%Y%m%d', event_date)) AS first_activity_date 
FROM `bigquery-public-data.ga4_obfuscated_sample_ecommerce.events_*`
group by user_pseudo_id), 

LATEST_DATE 
        AS ( -- same CTE 
select max(safe.parse_date('%Y%m%d', event_date)) as max_date 
 FROM `bigquery-public-data.ga4_obfuscated_sample_ecommerce.events_*`
 ),
USER_INACTIVITY
      AS ( 
 SELECT u.user_pseudo_id, u.last_activity_date,l.max_date,u.first_activity_date,  
 date_diff(l.max_date, u.last_activity_date, DAY ) as days_inactive ,
 date_diff(u.last_activity_date,u.first_activity_date ,day) as userlife_span
 from USER_LAST_ACTIVITY u 
 cross join latest_date l ) -- using cross join  becuase latest date has only 1 row. 

SELECT user_pseudo_id, last_activity_date, max_date, days_inactive, first_activity_date,userlife_span,
 CASE 
   WHEN USER_INACTIVITY.days_inactive between 0 and 30 then 'Active'
   WHEN USER_INACTIVITY.days_inactive between 31 and 60 then 'At Risk'
   WHEN USER_INACTIVITY.days_inactive between 61 and 90 then 'Likely Churned'
   ELSE  'Churned'
   END AS churn_group
   from USER_INACTIVITY
   order by days_inactive asc ; 

